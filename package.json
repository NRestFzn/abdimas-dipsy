{
  "name": "express-sequelize-typescript",
  "version": "1.0.0",
  "description": "Express API with TypeScript, Sequelize and MySql",
  "license": "ISC",
  "keywords": [
    "express",
    "api",
    "typescript",
    "sequelize"
  ],
  "author": "Nashir Resta Fauzian",
  "type": "commonjs",
  "main": "main.ts",
  "overrides": {
    "sequelize": {
      "uuid": "^11.1.1"
    }
  },
  "scripts": {
    "generate:secret": "node dist/helper/keyGenerate.js",
    "build": "rm -rf dist && tsc && tsc-alias",
    "build:dev": "rimraf dist && tsc && tsc-alias",
    "dev": "rimraf dist && tsc && tsc-alias && node dist/main.js",
    "start": "node dist/main.js",
    "dev:watch": "node --import=tsx --watch src/main.ts",
    "db:create": "sequelize-cli db:create",
    "db:drop": "sequelize-cli db:drop",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:refresh": "sequelize-cli db:migrate:undo:all",
    "db:seed": "sequelize-cli db:seed:all"
  },
  "dependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-useragent": "^1.0.5",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/multer": "^2.1.0",
    "@types/request-ip": "^0.0.41",
    "argon2": "^0.43.1",
    "colorette": "^2.0.20",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.0.1",
    "express-useragent": "^1.0.15",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.14.2",
    "nodemon": "^3.1.10",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.0.0",
    "request-ip": "^3.3.0",
    "rimraf": "^6.0.1",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5",
    "sequelize-typescript": "^2.1.6",
    "slugify": "^1.6.6",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "uuid": "^11.1.1",
    "yup": "^1.6.1",
    "zod": "^4.0.8"
  }
}
